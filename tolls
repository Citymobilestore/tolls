            // Update end date
            const endDate = new Date(startDate);
            if (period === 'hourly') endDate.setHours(endDate.getHours() + duration);
            else if (period === 'daily') endDate.setDate(endDate.getDate() + duration);
            else if (period === 'weekly') endDate.setDate(endDate.getDate() + (duration * 7));
            
            document.getElementById('endDate').valueAsDate = endDate;

            // Update summary
            document.getElementById('summaryRate').textContent = `$${rate}/${periodLabel}`;
            document.getElementById('summaryDuration').textContent = `${duration} ${periodLabel}${duration > 1 ? 's' : ''}`;
