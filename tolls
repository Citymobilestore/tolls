            const duration = parseInt(document.getElementById('rentalDuration').value);
            const startDate = document.getElementById('startDate').value;
            const endDate = document.getElementById('endDate').value;

            let rate;
            switch(period) {
                case 'hourly': rate = currentTool.hourly; break;
                case 'daily': rate = currentTool.daily; break;
                case 'weekly': rate = currentTool.weekly; break;
            }

            const total = (rate * duration) + 15 + currentTool.deposit;

            cart.push({
                ...currentTool,
                rentalPeriod: period,
                duration: duration,
                startDate: startDate,
                endDate: endDate,
                total: total,
                renterName: name,
